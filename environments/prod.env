# ==========================================
# Production Environment Configuration
# ==========================================
BASE_URL=https://production.venusenergy.com
ENVIRONMENT=prod

# ==========================================
# AI Framework Routing Settings
# ==========================================
# Primary LLM Provider (Options: groq, ollama, openai, local)
# If this provider fails, the framework automatically falls back: Groq -> Ollama (4m timeout) -> Local Code Generator
LLM_PROVIDER=groq

# Groq Settings
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=keyhere
# Ollama Settings (Local Fallback)
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=240000

# OpenAI Settings (Optional Backup)
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Settings (Optional Backup)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
